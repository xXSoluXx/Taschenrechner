__pycache__/          # Ordner mit automatisch generierten Python-Bytecode-Dateien
*.py[cod]             # Alle Python-Bytecode-Dateien (.pyc, .pyo, .pyd)
*$py.class             # Spezielle Python-Klassen-Dateien (z.B. Jython)

build/                # Ordner, der beim Erstellen/Verteilen von Python-Paketen entsteht
dist/                 # Distributionsordner (fertige Pakete)
*.egg-info/           # Informationen zu Python-Paketen
*.egg                 # Installierbare Python-Pakete

.vscode/              # VS Code Projekteinstellungen
.idea/                # PyCharm Projekteinstellungen
*.sublime-project     # Sublime Text Projektdateien
*.sublime-workspace   # Sublime Text Workspace-Dateien

.DS_Store             # macOS speichert Ordnerinformationen
Thumbs.db             # Windows speichert Vorschaubilder

*.log                 # Alle vom Programm erzeugten Log-Dateien